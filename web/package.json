{
  "name": "glitch-salvage-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:contracts": "npm run build --workspace @glitch/contracts",
    "build": "npm run build:contracts && npm run build --workspace @glitch/game",
    "dev": "npm run dev --workspace @glitch/game",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "9.17.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
