# ============================================================
# Glitch Salvage — environment template
# Copy to .env (PowerShell:  Copy-Item .env.example .env) and edit.
# NEVER commit the real .env — it is gitignored.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=glitch
POSTGRES_PASSWORD=change_me_pg
POSTGRES_DB=glitch_salvage
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async DSN used by the API (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://glitch:change_me_pg@postgres:5432/glitch_salvage
# Sync DSN used by Alembic migrations (psycopg)
DATABASE_URL_SYNC=postgresql+psycopg://glitch:change_me_pg@postgres:5432/glitch_salvage

# ---- Mosquitto MQTT broker ----
# These credentials are ALSO handed to the external Edge (Raspberry Pi) team.
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=glitch_edge
MQTT_PASSWORD=change_me_mqtt
MQTT_KEEPALIVE=60

# ---- JWT / Auth ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO
# Windows + Docker Desktop bind-mount file events are unreliable; force polling for --reload.
WATCHFILES_FORCE_POLLING=true

# ---- Ports exposed on the host (Docker Desktop) ----
API_PORT=8000
NGINX_PORT=80
MQTT_HOST_PORT=1883
POSTGRES_HOST_PORT=5432
