# Default: let git normalize text files
* text=auto eol=lf

# Force LF for files that MUST be LF inside Linux containers
# (CRLF here breaks shell scripts / Dockerfiles / yaml parsing)
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.mako      text eol=lf

# Python / TS source
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf

# Windows-specific helpers stay CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf

# Binary
*.png       binary
*.jpg       binary
*.ico       binary
